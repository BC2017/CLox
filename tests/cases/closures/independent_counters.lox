// Each invocation of makeCounter produces a closure with its own captured
// variable; the two counters must not share state.
// expect: 1
// expect: 1
// expect: 2
fun makeCounter() {
  var count = 0;
  fun increment() {
    count = count + 1;
    return count;
  }
  return increment;
}
var a = makeCounter();
var b = makeCounter();
print a();
print b();
print a();
